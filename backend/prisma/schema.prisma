generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Domain {
  UK
  DE
}

enum Site {
  TICKETMASTER
}

enum QueryStatus {
  FINDING   // bakılıyor, bilet yok
  FOUND     // bilet bulundu (isAvailable = true)
  STOPPED   // manuel durduruldu
  PURCHASED // frontend purchased status
  ERROR     // teknik hata
}

model Query {
  id                String       @id @default(uuid())

  domain            Domain
  site              Site
  eventId           String
  eventSlug         String?
  eventUrl          String
  section           String?                     // null = broad availability check (any section)
  minSeats          Int          @default(1)
  maxPrice          Int?                        // per-ticket ceiling in cents, null = no limit
  salePrice         Int?         // per-ticket sale price in cents
  orderNo           String       @default("")   // operational reference, not unique

  isActive          Boolean      @default(true)

  // Sistem durumu (frontend ana referansı)
  status            QueryStatus  @default(FINDING)

  // Son kontrol sonucu
  lastCheckedAt     DateTime?
  isAvailable       Boolean      @default(false)
  foundPrice        Int?                         // last matched price in cents
  priceExceeded     Boolean      @default(false) // true when tickets found but price > maxPrice
  lastErrorMessage  String?
  eventName         String?
  eventLocation     String?                      // city/locality from LD+JSON
  eventDate         String?                      // date portion of startDate

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Log ilişkisi
  results           CheckResult[]

  // Unique constraint removed to allow multiple queries for same event+section
}

model CheckResult {
  id            String        @id @default(uuid())

  queryId       String
  query         Query         @relation(fields: [queryId], references: [id], onDelete: Cascade)

  checkedAt     DateTime      @default(now())
  status        QueryStatus
  isAvailable   Boolean
  foundPrice    Int?                         // price snapshot at check time (cents)
  priceExceeded Boolean       @default(false)

  eventName     String?
  httpStatus    Int?
  errorMessage  String?
  latencyMs     Int?

  @@index([queryId])
}
